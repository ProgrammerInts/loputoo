apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    orgId: 1
    uid: prometheus_ds
    url: http://localhost:{{ prometheus_port }}
    version: 1
    isDefault: true
    editable: true

  - name: Loki
    type: loki
    access: proxy
    orgId: 1
    uid: loki_ds
    url: http://localhost:{{ loki_port }}
    version: 1
    isDefault: false
    editable: true
